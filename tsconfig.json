{
    "compilerOptions": {
        "target": "ES2021",
        "module": "nodenext",
        "rootDir": "./src",
        "outDir": "dist",
        "sourceMap": true,
        "allowJs": true,
        "esModuleInterop": true,
        "moduleResolution": "nodenext",
        "skipLibCheck": true
    },
    "ts-node": {
        "files": true
    },
    "include": [
        "./src",
        "src/slashRegistry.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}